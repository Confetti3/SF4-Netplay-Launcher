# Dashboard listen port (localhost only; Caddy reverse-proxies :443 -> this port)
DASHBOARD_PORT=8789

# Bind address (127.0.0.1 behind Caddy; use 0.0.0.0 only for dev without TLS)
DASHBOARD_BIND=127.0.0.1

# Trust X-Forwarded-For from Caddy on loopback
DASHBOARD_TRUST_PROXY=1

# Admin credentials
ADMIN_USERNAME=admin
# Generate with: node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# Session signing secret (random 32-byte hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Session lifetime in seconds (default 8 hours)
SESSION_TTL_SEC=28800

# Internal relay-manager URL (must stay on localhost)
RELAY_MANAGER_URL=http://127.0.0.1:8788

# Internal room broker URL (must stay on localhost)
BROKER_URL=http://127.0.0.1:8787

# Secure cookies when served over HTTPS (auto-enabled when DASHBOARD_BIND=127.0.0.1)
COOKIE_SECURE=1

# Shown in dashboard header (operator reference)
DASHBOARD_CLIENT_VERSION=0.3.6

# Public broker URL for quick links (HTTPS, via Caddy)
DASHBOARD_PUBLIC_BROKER_URL=https://74-208-200-95.nip.io
