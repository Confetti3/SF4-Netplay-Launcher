PORT=8787
# Bind localhost only; expose broker via Caddy on :443 (see install-caddy.sh)
BROKER_BIND=127.0.0.1
# Trust X-Forwarded-For only from Caddy on 127.0.0.1 (set 0 for direct public bind in dev)
BROKER_TRUST_PROXY=1
# Public HTTPS URL for launcher (after Caddy + DNS)
# BROKER_PUBLIC_URL=https://netplay.example.com
RELAY_HOST=your.vps.ip
RELAY_PORT_BASE=23456
# Maximum simultaneously allocated VPS rooms.
# Each room reserves one session relay port and, in auto mode, one GGPO UDP relay port.
# Default ranges with MAX_ROOMS=50:
#   Session relay: 23456–23505 TCP/UDP
#   GGPO UDP relay: 24456–24505 UDP
MAX_ROOMS=50
# Soft operator/dashboard warning threshold (does not block room creation).
ROOM_CAPACITY_WARNING_PERCENT=80
# Empty host-only lobby (no joiner): drop room after 5 min idle
ROOM_LOBBY_IDLE_MS=300000
# Guest registered or match started: 0 disables age-based cleanup.
# The host can still delete the room explicitly; empty host-only rooms use the timeout above.
ROOM_OCCUPIED_IDLE_MS=0
# Legacy alias for ROOM_OCCUPIED_IDLE_MS if the vars above are unset
# ROOM_IDLE_MS=900000
FORCE_VPS_RELAY=1
RELAY_MANAGER_URL=http://127.0.0.1:8788
BROKER_ENABLE_ROOM_LIST=0
# Set to 1 when using the VPS dashboard (needs room/match listing).
# BROKER_GGPO_TRANSPORT=legacy|auto (auto spawns paired GGPO UDP relay)
BROKER_GGPO_TRANSPORT=auto
GGPO_UDP_PORT_BASE=24456
NAT_PROBE_PORT=8790
# NAT probe must stay on a public UDP port (not behind Caddy)
NAT_PROBE_BIND=0.0.0.0
